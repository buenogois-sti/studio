
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // --- Funções Auxiliares de Elite ---
    function isAuthenticated() {
      return request.auth != null && request.auth.uid != null;
    }

    function getUserRole() {
      return request.auth.token.role;
    }

    function isOneOfRoles(roles) {
      return isAuthenticated() && (getUserRole() in roles);
    }

    function isStaff() {
      // Se o usuário está autenticado e tem um registro de perfil no sistema ou claim de cargo, é considerado Staff.
      // Isso resolve erros de "Missing Permissions" durante períodos de propagação de token.
      return isAuthenticated() && (
        getUserRole() != null || 
        exists(/databases/$(database)/documents/users/$(request.auth.uid))
      );
    }

    function isAdmin() {
      // Robust check: token claim or direct database property
      return isOneOfRoles(['admin']) || 
             (isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    function isFinancial() {
      return isOneOfRoles(['financial']) || 
             (isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'financial');
    }

    function isOwner(userId) {
      return isAuthenticated() && (request.auth.uid == userId || isAdmin());
    }

    // --- Regras por Coleção ---
    
    // Perfil de Usuário
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow update: if isOwner(userId) || isAdmin();
      allow create, delete: if isAdmin();

      match /notifications/{notificationId} {
        allow read, update, delete: if isOwner(userId) || isAdmin();
        allow create: if isAuthenticated();
      }

      match /logs/{logId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isAuthenticated();
      }
    }

    // CRM & Gestão de Clientes
    match /clients/{clientId} {
      allow read: if isStaff();
      allow create, update: if isOneOfRoles(['admin', 'lawyer', 'assistant']);
      allow delete: if isAdmin();
    }

    // Gestão de Leads (Triagem)
    match /leads/{leadId} {
      allow read: if isStaff();
      allow create, update: if isStaff();
      allow delete: if isAdmin();
    }

    // Processos Judiciais
    match /processes/{processId} {
      allow read: if isStaff();
      allow create, update: if isOneOfRoles(['admin', 'lawyer', 'assistant']);
      allow delete: if isAdmin();
    }

    // Agenda: Audiências e Prazos
    match /hearings/{hearingId} {
      allow read: if isStaff();
      allow write: if isOneOfRoles(['admin', 'lawyer', 'assistant']);
      allow delete: if isAdmin();
    }

    match /deadlines/{deadlineId} {
      allow read: if isStaff();
      allow write: if isOneOfRoles(['admin', 'lawyer', 'assistant']);
      allow delete: if isAdmin();
    }

    // FINANCEIRO CENTRAL (Crítico)
    match /financial_events/{eventId} {
      allow read, write: if isAdmin() || isFinancial();
    }

    match /financial_titles/{titleId} {
      allow read, write: if isAdmin() || isFinancial();
    }

    // Contas Bancárias (Gestão Financeira)
    match /bank_accounts/{accountId} {
      allow read, write: if isAdmin() || isFinancial();
    }

    // Correspondentes e Parceiros Externos
    match /correspondents/{correspondentId} {
      allow read, write: if isAdmin() || isFinancial();
      allow read: if isStaff();
    }

    // Folha de Pagamento (Módulo RH e Financeiro)
    match /payroll/{payrollId} {
      allow read, write: if isAdmin() || isFinancial();
    }

    // Auditoria de Roles e Acessos
    match /user_roles/{email} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Reembolsos (Privacidade do Colaborador)
    match /reimbursements/{reimbursementId} {
      allow read: if isAdmin() || isFinancial() || resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated();
      allow update: if isAdmin() || isFinancial();
      allow delete: if isAdmin() || (resource.data.userId == request.auth.uid && resource.data.status == 'SOLICITADO');
    }
    
    // Equipe & Repasses
    match /staff/{staffId} {
      allow read: if isStaff();
      allow create: if isAdmin();
      allow update: if isAdmin() || (
        isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.staffId == staffId &&
        // Proteção contra alteração de campos sensíveis por não-admins
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'status', 'remuneration', 'email'])
      );
      allow delete: if isAdmin();

      match /credits/{creditId} {
        allow read: if isAdmin() || isFinancial() || isOwner(staffId);
        allow write: if isAdmin() || isFinancial();
      }
    }

    // Bibliotecas e Configurações
    match /document_templates/{templateId} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    match /checklist_templates/{templateId} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    match /checklist_executions/{executionId} {
      allow read: if isStaff();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    match /system_settings/{settingId} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    // Gestão de Tarefas (Sincronização Google e Fluxos Internos)
    match /tasks/{taskId} {
      allow read: if isStaff();
      allow write: if isOneOfRoles(['admin', 'lawyer', 'assistant']);
      allow delete: if isAdmin();
    }
    
    // Monitoramento de Diários Oficiais / Central de Intimações AASP (Suporte a múltiplas filas/advogados)
    match /{collectionId}/{docId} {
      allow read: if collectionId.matches('intimacoes.*') && isAuthenticated();
      allow write: if collectionId.matches('intimacoes.*') && isOneOfRoles(['admin', 'lawyer', 'assistant']);
      allow delete: if collectionId.matches('intimacoes.*') && isAdmin();
    }
  }
}
